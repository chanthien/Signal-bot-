# ── Telegram ──────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
CHANNEL_ID=-100xxxxxxxxxx
MY_CHAT_ID=123456789

# ── BingX Futures API ─────────────────────────────────────
# Lưu ý: không có khoảng trắng / newline ở đầu-cuối key & secret
BINGX_API_KEY=your_bingx_api_key
BINGX_API_SECRET=your_bingx_api_secret

# ── Server ────────────────────────────────────────────────
PORT=8000

# ── Optional asset groups ─────────────────────────────────
# bật thêm nhóm coin rác/alt (ARC, MYX, POWER, PHA, B, BABY, PIPPIN, ADA, MAGIC, RIVER, TAU, DAM, EUL)
ENABLE_MEME_GROUP=false

# ── Docker image (optional override) ──────────────────────
# Nếu để trống, docker-compose dùng mặc định:
# ghcr.io/YOUR_USERNAME/signal-bot/signal-bot:latest
IMAGE_NAME=
