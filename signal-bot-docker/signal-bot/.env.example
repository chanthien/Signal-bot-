# ── Telegram ──────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
CHANNEL_ID=-100xxxxxxxxxx
MY_CHAT_ID=123456789

# ── BingX Futures API ─────────────────────────────────────
# Chỉ cần khi EXECUTION_ENABLED=true (mặc định false)
BINGX_API_KEY=your_bingx_api_key
BINGX_API_SECRET=your_bingx_api_secret

# ── Server ────────────────────────────────────────────────
PORT=8000

# ── Runtime mode ──────────────────────────────────────────
# false = signal-only (không tự động vào lệnh BingX)
# true  = bật auto execution (khi bạn sẵn sàng)
EXECUTION_ENABLED=false

# ── Optional asset groups ─────────────────────────────────
ENABLE_MEME_GROUP=false

# ── Optional external executor URL ────────────────────────
# để trống nếu chạy signal-only 1 container
# ví dụ: http://signal-bot-executor:8010
EXECUTOR_BASE_URL=

# ── Optional GHCR image (chỉ dùng với docker-compose.ghcr.yml) ─
# Ví dụ: ghcr.io/your_username/signal-bot/signal-bot:latest
IMAGE_NAME=
